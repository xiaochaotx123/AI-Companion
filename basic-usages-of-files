"""

f.seek(0)
# f.readline()方法：读取文件的第一行，返回一个字符串
# f.readline(4)方法：读取文件第一行的前4个字符，返回一个字符串
line = f.readline()
print(line)

f.seek(0)
# f.readlines()方法：读取文件的所有行，返回一个list列表，列表中的元素就是每一行形成的字符串
lines = f.readlines() # 打印：['你好，今天是2026年6月27日\n', '今天天气很晴朗\n', '但是我很困\n']
print(lines)

# 注意：不要使用read()或者readlines()方法一次性加载GB级文件，会占用大量的内存，导致程序崩溃
# 可以使用for循环：for line in f:逐行迭代，内部使用缓冲区，效率高且内存占用低
# 温故：字符串的strip()方法：用于取出字符串开头和结尾的多余字符，默认是空格和换行符。它不会修改原来的字符，而是返回一个新的结果
f.seek(0)
for line in f:
    print(line.strip())

# 3.关闭文件
# 注意：如果操作完文件，并未调用close方法，同时程序没有停止运行，那么这个文件将一只被Python程序占用，无法操作！
f.close()


# 1.打开文件
f = open(r"C:\Users\33743\Desktop\develop\python_project\AI应用\usefile_test_write", "w", encoding = "utf-8")

# 2.写入文件内容
# f.write()方法就是直接在文件的末尾继续写入字符串
# f.writelines()方法也是在文件的末尾继续写入字符串，可以写入一个list列表，列表中的每个元素都是字符串
f.write("静夜思（李白）\n\n")
f.writelines(["长纤明月光，\n", "疑是地下霜。\n"])

# 3.关闭文件
f.close()
# 注意：write()不会自动添加换行符号，需要手动添加\n
